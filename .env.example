# 复制本文件为 .env 并填入你的 key（.env 已被 git 忽略，不会泄露）
# DeepSeek API Key —— https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 可选：DeepSeek 模型，默认 deepseek-chat（写文章足够、快且便宜）；更强推理可用 deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# 可选：后端端口，默认 8787
PORT=8787

# 可选：Apimart key。留空则自动读取 article-illustrator/config.json 里的 api_key
APIMART_API_KEY=

# 可选：Tavily 联网检索 key —— https://tavily.com （有免费额度）
# 配了它，勾选「联网检索」就能在写文前自动抓取实时新闻，避免对新事件产生幻觉
TAVILY_API_KEY=
